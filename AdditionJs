<!DOCTYPE html>
<html>
<head>
<title>Addition of Two Numbers</title>

<script>
function addNumbers()
{
    var num1 = parseInt(document.getElementById("n1").value);
    var num2 = parseInt(document.getElementById("n2").value);

    var sum = num1 + num2;

    document.getElementById("result").innerHTML = "Sum = " + sum;
}
function subNumbers()
{
    var num1 = parseInt(document.getElementById("n1").value);
    var num2 = parseInt(document.getElementById("n2").value);

    var sub = num1 - num2;

    document.getElementById("result").innerHTML = "Substraction = " + sub;
}
</script>

</head>

<body>

<h2>Addition of Two Numbers using JavaScript</h2>

Enter First Number:
<input type="number" id="n1"><br><br>

Enter Second Number:
<input type="number" id="n2"><br><br>

<button onclick="addNumbers()">Add</button>
<button onclick="subNumbers()">Sub</button>

<h3 id="result"></h3>

</body>
</html>
